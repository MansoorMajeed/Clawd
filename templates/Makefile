# Makefile — configured during /plan-init based on your tech stack
#
# Single source of truth for build/test/lint commands.
# The agent ALWAYS uses these targets instead of raw commands.
#
# Pattern for multi-component projects:
#
#   test-backend:
#       cd backend && go test ./...
#   test-frontend:
#       cd frontend && npm test
#   test: test-backend test-frontend

.PHONY: test lint fmt check build coverage

## Run test suite
test:
	@echo "ERROR: Makefile not configured. Run /plan-init to set up targets."
	@exit 1

## Run linters
lint:
	@echo "ERROR: Makefile not configured. Run /plan-init to set up targets."
	@exit 1

## Format code
fmt:
	@echo "ERROR: Makefile not configured. Run /plan-init to set up targets."
	@exit 1

## Pre-commit gate: format, lint, test
check: fmt lint test

## Build the project
build:
	@echo "ERROR: Makefile not configured. Run /plan-init to set up targets."
	@exit 1

## Run test coverage report
coverage:
	@echo "ERROR: Makefile not configured. Run /plan-init to set up targets."
	@exit 1
