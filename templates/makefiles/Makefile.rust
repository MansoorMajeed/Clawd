.PHONY: test lint fmt check build coverage

## Run test suite
test:
	cargo test

## Run linters
lint:
	cargo clippy -- -D warnings

## Format code
fmt:
	cargo fmt

## Pre-commit gate: format, lint, test
check: fmt lint test

## Build the project
build:
	cargo build

## Run test coverage report
coverage:
	cargo tarpaulin --out Html
