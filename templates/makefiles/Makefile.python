.PHONY: test lint fmt check build coverage

## Run test suite
test:
	pytest

## Run linters
lint:
	ruff check .

## Format code
fmt:
	ruff format .

## Pre-commit gate: format, lint, test
check: fmt lint test

## Build the project (no-op for Python)
build:
	@echo "No build step for Python"

## Run test coverage report
coverage:
	pytest --cov --cov-report=term-missing
